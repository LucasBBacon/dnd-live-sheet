# Dependencies
node_modules/
**/node_modules/

# Build output
build/
dist/
**/dist/
out/
**/out/
coverage/
**/coverage/

# Server generated artifacts should never live in source tree
apps/server/src/**/*.js
apps/server/src/**/*.js.map
apps/server/src/**/*.d.ts
apps/server/src/**/*.d.ts.map

# TypeScript incremental artifacts
*.tsbuildinfo
**/*.tsbuildinfo

# Turborepo cache
.turbo/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment files (secrets/local config)
.env
.env.*
!.env.example
!.env.*.example

# Local-only overrides
*.local

# Runtime files
pids/
*.pid
*.pid.lock

# Editor and OS artifacts
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
